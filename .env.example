# Copy to .env and fill in real values locally. NEVER commit .env.
# Real secrets go in the hosting platform's env settings (Render/Railway), not the repo.

# Google Gemini API key for the reasoning layer.
# If unset, the service automatically uses the deterministic rule-based engine.
GEMINI_API_KEY=my_gcp_api_key_here

# Model id for the reasoning layer.
MODEL_NAME=gemini-flash-latest

# Hard timeout (seconds) for the LLM call before falling back to rules.
LLM_TIMEOUT_SECONDS=12

# Port the service binds (must bind 0.0.0.0 for judging).
PORT=8000
